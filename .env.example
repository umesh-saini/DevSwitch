# ── GitHub OAuth Configuration ────────────────────────────────────────────────
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Fill in the application details:
#    - Application name: DevSwitch (or your preferred name)
#    - Homepage URL: http://localhost:5173
#    - Authorization callback URL: http://localhost:<PORT>/oauth/callback
#      (DevSwitch auto-selects a port in the 54876–54885 range)
# 4. Copy the Client ID and Client Secret below

GITHUB_CLIENT_ID=<YOUR_CLIENT_ID_HERE>
GITHUB_CLIENT_SECRET=<YOUR_CLIENT_SECRET_HERE>

# ── GitLab OAuth Configuration ────────────────────────────────────────────────
# 1. Go to https://gitlab.com/-/profile/applications
# 2. Click "Add new application"
# 3. Fill in the application details:
#    - Name: DevSwitch
#    - Redirect URI: http://localhost:54886/oauth/callback
#      (DevSwitch auto-selects a port in the 54886–54895 range)
#    - Scopes: api, read_user
# 4. Copy the Application ID and Secret below

GITLAB_CLIENT_ID=<YOUR_CLIENT_ID_HERE>
GITLAB_CLIENT_SECRET=<YOUR_CLIENT_SECRET_HERE>


# General Configuration
NODE_ENV=development